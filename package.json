  "description": "Hexlet QA market",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^8.3.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "bootstrap": "^5.3.8",
    "fastify": "^5.8.5",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.1.0",
    "i18next": "^26.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.16.0",
    "redux-saga": "^1.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "fastify start -w -l info -P -p 3001 server/app.js",
    "build": "vite build",
    "preview": "vite preview",
    "start:prod": "fastify start -l info -a 0.0.0.0 -p ${PORT:-8080} server/app.js",
    "test": "vitest run",
    "lint": "biome check .",
    "lint-fix": "biome check --write ."
  },
  "engines": {
    "node": ">=26.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "npm-check-updates": "^22.2.1",
    "vitest": "^4.1.7"
  }
